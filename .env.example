# =============================================================================
# PROPERTY ESCROW PLATFORM - REQUIRED ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control

# =============================================================================
# ESSENTIAL CONFIGURATION
# =============================================================================

# Alchemy/Polygon RPC Endpoint (REQUIRED)
# Get your API key from: https://www.alchemy.com/
REACT_APP_ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Private key for contract deployment (REQUIRED for deployment)
# SECURITY WARNING: Keep this secret and never commit to version control
PRIVATE_KEY=your_private_key_here

# Platform wallet address (REQUIRED - receives platform fees)
PLATFORM_WALLET=0x0000000000000000000000000000000000000000

# =============================================================================
# OPTIONAL CONFIGURATION
# =============================================================================

# Platform fee in basis points (default: 250 = 2.5%, max: 500 = 5%)
PLATFORM_FEE=250

# PolygonScan API Key for contract verification (optional)
# Get from: https://polygonscan.com/apis
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Environment (development, staging, production)
NODE_ENV=development

# Frontend development port (default: 3000)
PORT=3000

# =============================================================================
# NOTES
# =============================================================================
#
# REQUIRED VARIABLES:
# - REACT_APP_ALCHEMY_RPC_URL: Essential for blockchain connectivity
# - PRIVATE_KEY: Required for contract deployment only
# - PLATFORM_WALLET: Address that receives platform fees
#
# SETUP INSTRUCTIONS:
# 1. Create Alchemy account at https://www.alchemy.com/
# 2. Create new app with Polygon Mainnet
# 3. Copy the HTTP URL to REACT_APP_ALCHEMY_RPC_URL
# 4. Set PLATFORM_WALLET to your fee collection address
# 5. Only set PRIVATE_KEY if deploying contracts
#
# SECURITY:
# - Never commit .env files to version control
# - Keep private keys secure and rotate regularly
# - Use different keys for development vs production
#
# =============================================================================
