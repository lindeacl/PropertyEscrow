modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-24_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Hardhat Development Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "escrow_test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Escrow Platform Tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Escrow Tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "UI Test Suite"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Smart Contract Tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy Contracts"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Static Frontend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Production Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Static Production Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Accessible Frontend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Frontend Development Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Static Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Working Frontend Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Logging Demo Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Simple Logging Demo"

[[workflows.workflow]]
name = "Hardhat Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm run test && npm run deploy:localhost"

[[workflows.workflow]]
name = "escrow_test"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install && npm test"

[[workflows.workflow]]
name = "Escrow Platform Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat test"

[[workflows.workflow]]
name = "Run Escrow Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat test"

[[workflows.workflow]]
name = "UI Test Suite"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run test:coverage"

[[workflows.workflow]]
name = "Smart Contract Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat test"

[[workflows.workflow]]
name = "Deploy Contracts"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat run scripts/deploy.js --network localhost"

[[workflows.workflow]]
name = "Static Frontend Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run build && npx serve -s build -l 5000"
waitForPort = 5000

[[workflows.workflow]]
name = "Production Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run build && cd .. && node simple-server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Static Production Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node frontend-server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Accessible Frontend Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && HOST=0.0.0.0 PORT=5000 npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "Frontend Development Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && HOST=0.0.0.0 PORT=5000 npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "Static Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npx serve -s build -l 5000 -H 0.0.0.0"
waitForPort = 5000

[[workflows.workflow]]
name = "Working Frontend Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm install && HOST=0.0.0.0 PORT=5000 npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "Logging Demo Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm install --legacy-peer-deps && HOST=0.0.0.0 PORT=5000 npm start"
waitForPort = 5000

[[workflows.workflow]]
name = "Simple Logging Demo"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m http.server 5000"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "npm install && npm run test && npm run deploy:localhost"]

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8545
externalPort = 80

[[ports]]
localPort = 8546
externalPort = 3000
