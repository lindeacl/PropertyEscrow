# =============================================================================
# FRONTEND ENVIRONMENT CONFIGURATION
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# Alchemy Polygon RPC URL (REQUIRED)
# Get your API key from: https://www.alchemy.com/
# Create new app → Polygon Mainnet → Copy HTTP URL
REACT_APP_ALCHEMY_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY_HERE

# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# Development server port (default: 3000)
PORT=3000

# React development mode (default: development)
NODE_ENV=development

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Sign up at https://www.alchemy.com/
# 2. Create new app with these settings:
#    - Chain: Polygon
#    - Network: Polygon Mainnet
# 3. Copy the HTTP URL from your app dashboard
# 4. Replace YOUR_API_KEY_HERE with your actual API key
# 5. Save as .env.local (not .env.example)
#
# SECURITY NOTE:
# - Never commit .env.local to version control
# - API keys should be kept secret
#
# =============================================================================